# Test environment variables for Citation Management Agent
LLM_API_KEY=test_key_for_testing_only
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o-mini
LLM_BASE_URL=https://api.openai.com/v1

# Citation Processing
CITATION_BATCH_SIZE=50
DUPLICATE_THRESHOLD=0.85
VALIDATE_CITATIONS=true

# Application Settings
APP_ENV=test
LOG_LEVEL=INFO
DEBUG=true
MAX_RETRIES=3
TIMEOUT_SECONDS=30