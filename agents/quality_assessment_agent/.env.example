# Quality Assessment Agent Environment Configuration

# Required: OpenAI API Configuration
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o-mini
OPENAI_BASE_URL=https://api.openai.com/v1

# Optional: Fact-checking API
FACT_CHECK_API_KEY=your_factcheck_api_key_here

# Quality Assessment Configuration
CREDIBILITY_THRESHOLD=0.7
BIAS_THRESHOLD=0.6
PROCESSING_TIMEOUT=30
MAX_CONCURRENT_ASSESSMENTS=10

# Agent Configuration
AGENT_ID=quality_assessment_agent
AGENT_VERSION=1.0.0

# Scoring Weights (should sum to 1.0 for credibility assessment)
DOMAIN_AUTHORITY_WEIGHT=0.30
CONTENT_QUALITY_WEIGHT=0.25
AUTHOR_CREDENTIALS_WEIGHT=0.20
SOURCE_TYPE_WEIGHT=0.15
FRESHNESS_WEIGHT=0.10